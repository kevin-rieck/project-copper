{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "audit:all": "npm audit --audit-level=moderate",
    "ci": "npm run audit:prod && npm run test && npm run build"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.4.22",
    "jsdom": "29.1.1",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
